# ====== Security: Default deny ======
<FilesMatch ".*">
    Order allow,deny
    Deny from all
</FilesMatch>

# ====== Allow only image, document, script, style, dan text files ======
<FilesMatch "\.(jpg|jpeg|png|gif|bmp|webp|svg|pdf|doc|docx|js|css|json|scss|txt)$">
    Order deny,allow
    Allow from all
</FilesMatch>

# ====== Deny execution of PHP files ======
<FilesMatch "\.(php|php[0-9]*|phtml)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ====== Extra: Disable PHP engine completely (for mod_php) ======
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# ====== Optional: Disable script execution via CGI ======
Options -ExecCGI

# ====== Optional: Security Headers ======
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>